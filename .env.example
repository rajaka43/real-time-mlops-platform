# ─────────────────────────────────────────────────────────
# MLOps Platform — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO
DEBUG=false

# Model Registry
MODEL_REGISTRY_PATH=models/registry
MODEL_ARTIFACTS_PATH=models/artifacts
MIN_ACCURACY_TO_PROMOTE=0.005

# Drift Detection
DRIFT_WINDOW_SIZE=500
DRIFT_CHECK_INTERVAL=50
DRIFT_PSI_THRESHOLD=0.20
RETRAINING_DRIFT_THRESHOLD=3

# MLflow Experiment Tracking
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=mlops-platform

# Redis Cache
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=3600

# CI/CD Quality Gate Thresholds
MIN_ACCURACY=0.75
MIN_F1_SCORE=0.70

# Production Deployment (GitHub Actions secrets)
# PRODUCTION_API_URL=https://your-api.example.com
# API_KEY=your-secret-api-key
